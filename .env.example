# Copy to .env and fill in values for local dev.
# In production these are set as Cloud Run environment variables / secrets.

# --------------------------------------------------------------------------
# Auth mode A: Gemini API key (simplest for local dev)
# Get one at https://aistudio.google.com/apikey
# --------------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here

# --------------------------------------------------------------------------
# Auth mode B: Application Default Credentials via Vertex AI (recommended)
# Leave GOOGLE_API_KEY empty and run:
#   gcloud auth application-default login
# The agents will automatically use your gcloud identity.
# --------------------------------------------------------------------------

# Google Cloud project ID (required for ADC / Vertex AI mode)
GOOGLE_CLOUD_PROJECT=researchbrain-497600

# Google Cloud region for Vertex AI and Cloud Run deployment
GOOGLE_CLOUD_REGION=us-central1

# --------------------------------------------------------------------------
# Server settings (used by agents/server.py)
# --------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Use * for local dev; restrict to your Vercel URL in production.
# Example: https://govihitha.vercel.app,https://govihitha-git-main.vercel.app
ALLOWED_ORIGINS=*
